# Copy this file to deploy/stack.env and replace placeholder values before running docker compose.

# MCP server application settings
UYUNI_SERVER=uyuni.example.internal:443
UYUNI_MCP_SSL_VERIFY=true
UYUNI_MCP_WRITE_TOOLS_ENABLED=false
UYUNI_MCP_LOG_LEVEL=INFO
UYUNI_MCP_LOG_FILE_PATH=
UYUNI_PRODUCT_NAME=Uyuni
UYUNI_MCP_PUBLIC_URL=http://127.0.0.1:8000
UYUNI_SSH_PRIV_KEY=
UYUNI_SSH_PRIV_KEY_PASS=

# Host-side published ports
MCP_BIND_HOST=127.0.0.1
MCP_BIND_PORT=8000
KEYCLOAK_BIND_PORT=8080

# Keycloak runtime settings
KEYCLOAK_IMAGE_TAG=26.1.4
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
KEYCLOAK_REALM=uyuni-mcp
KEYCLOAK_PUBLIC_HOSTNAME=localhost
KEYCLOAK_PUBLIC_PORT=8080

# MCP OAuth issuer as seen by the MCP container.
# In the checked-in local runtime file, this uses the Docker service URL.
# For a non-containerized local server, this would typically be the browser-facing Keycloak URL instead.
UYUNI_AUTH_SERVER=http://localhost:8080/realms/uyuni-mcp

# Optional Cloudflare profile settings for later EC2 deployment or tunnel testing.
CLOUDFLARED_IMAGE_TAG=latest
CLOUDFLARE_TUNNEL_TOKEN=replace-with-dashboard-token