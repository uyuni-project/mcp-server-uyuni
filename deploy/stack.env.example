# Copy this file to deploy/stack.env and replace placeholder values before running docker compose.

# Required for this deployment

# Uyuni API hostname on the shared Podman network.
UYUNI_SERVER=uyuni-server
# Public MCP base URL used by clients (without trailing /mcp).
# The MCP discovery endpoint advertises this value as the protected resource URL.
UYUNI_MCP_PUBLIC_URL=http://<container_hostname_or_ip>:8000
# Host port published for MCP HTTP endpoint.
MCP_BIND_PORT=8000
# Host port published for Keycloak HTTP endpoint.
KEYCLOAK_BIND_PORT=8080
# Host port published for Keycloak DCR-sanitizing proxy endpoint.
KEYCLOAK_DCR_PROXY_BIND_PORT=8081
# Initial Keycloak admin username created at startup.
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
# Initial Keycloak admin password created at startup.
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Optional defaults (usually keep as-is)

# Verify TLS certificates when MCP connects to Uyuni HTTPS endpoints.
UYUNI_MCP_SSL_VERIFY=false
# Enable tools that make write/state-changing Uyuni actions.
UYUNI_MCP_WRITE_TOOLS_ENABLED=true
# Product label shown by the MCP server.
UYUNI_PRODUCT_NAME=Uyuni
# Keycloak container image tag.
KEYCLOAK_IMAGE_TAG=26.1.4
# Application log verbosity for MCP server.
UYUNI_MCP_LOG_LEVEL=INFO
# Public hostname Keycloak advertises in issuer/discovery metadata.
# Keep `keycloak` in most setups; for host-native clients, map `keycloak` in `/etc/hosts`.
KEYCLOAK_PUBLIC_HOSTNAME=keycloak
# Public port Keycloak advertises in issuer/discovery metadata.
KEYCLOAK_PUBLIC_PORT=8080
# OIDC issuer URL used by the MCP server to validate/advertise auth metadata.
# Must match Uyuni `web.oidc.idp.issuer` exactly.
UYUNI_AUTH_SERVER=http://keycloak:8080/realms/uyuni-mcp

# Optional advanced settings (leave empty unless needed)

# Optional MCP log file path inside container (empty = stdout only).
UYUNI_MCP_LOG_FILE_PATH=
# Private key content used by SSH bootstrap-related tools.
UYUNI_SSH_PRIV_KEY=
# Passphrase for UYUNI_SSH_PRIV_KEY if the key is encrypted.
UYUNI_SSH_PRIV_KEY_PASS=
